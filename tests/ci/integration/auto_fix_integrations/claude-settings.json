{
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      "Bash(git checkout *)",
      "Bash(git reset *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git diff *)",
      "Bash(git status *)",
      "Bash(git add *)",
      "Bash(git rm *)",
      "Bash(git commit *)",
      "Bash(git rev-list *)",
      "Bash(git rev-parse *)",
      "Bash(patch *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(wget *)"
    ],
    "deny": [
      "Bash(git config core.* *)",
      "Bash(git -c *)",
      "Bash(git clone *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git remote *)",
      "Bash(curl *)",
      "Bash(rm *)",
      "Bash(nc *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(aws *)",
      "Bash(eval *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(apt *)",
      "Bash(apt-get *)",
      "Bash(brew *)",
      "Bash(docker *)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "enableWeakerNestedSandbox": true,
    "network": {
      "allowedDomains": [
        "downloads.nwtime.org"
      ]
    },
    "filesystem": {
      "denyRead": ["~/.aws", "~/.ssh"]
    }
  }
}
